generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  campaigns      Campaign[]
  providerConfig ProviderConfig?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ProviderConfig {
  id                 String   @id @default(cuid())
  userId             String   @unique
  provider           String   @default("gmail")
  providerEmail      String   @default("")
  providerCredential String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@unique([token])
}

model Campaign {
  id                 String   @id @default(cuid())
  userId             String
  name               String   @default("")
  status             String   @default("draft")
  scheduledAt        DateTime?
  sendNow            Boolean  @default(false)
  sendDelay          Int      @default(0)
  subject            String   @default("")
  htmlBody           String   @default("")
  templateStyle      String   @default("professional")
  provider           String   @default("")
  providerEmail      String   @default("")
  providerCredential String   @default("")
  recipientCount     Int      @default(0)
  sent               Int      @default(0)
  failed             Int      @default(0)
  chatHistory        Json     @default("[]")
  archivedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}
